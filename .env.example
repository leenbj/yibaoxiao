# 易报销 Pro - 环境变量配置示例
# 复制此文件为 .env 并修改配置
# cp .env.example .env

# ==================== Supabase 配置 ====================
# 从 Supabase Dashboard > Settings > API 获取
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ==================== 镜像版本（Docker 部署）====================
IMAGE_TAG=latest

# ==================== Node.js 配置 ====================
# 内存限制（MB），针对 4G 内存服务器建议 1024
NODE_OPTIONS=--max-old-space-size=1024
